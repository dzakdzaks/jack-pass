# JackPass production nginx example (HTTPS via certbot or your TLS terminator).
#
# 1. bun run build
# 2. Copy dist/ to /var/www/jackpass (or set root below)
# 3. Replace example.com with your domain
# 4. sudo ln -s .../deploy/nginx.conf.example /etc/nginx/sites-available/jackpass
# 5. sudo certbot --nginx -d example.com
#
# CSP must stay aligned with security/csp.ts (production directives).

map $sent_http_content_type $jackpass_asset_cache {
    default                    "public, max-age=0, must-revalidate";
    "~*text/html"              "no-store";
    "~*application/javascript" "public, max-age=31536000, immutable";
    "~*text/css"               "public, max-age=31536000, immutable";
    "~*image/"                 "public, max-age=31536000, immutable";
    "~*font/"                  "public, max-age=31536000, immutable";
    "~*manifest"               "public, max-age=86400";
}

server {
    listen 80;
    listen [::]:80;
    server_name example.com;
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name example.com;

    # certbot fills these paths after `certbot --nginx`
    ssl_certificate     /etc/letsencrypt/live/example.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/example.com/privkey.pem;
    include /etc/letsencrypt/options-ssl-nginx.conf;
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem;

    root /var/www/jackpass;
    index index.html;

    # --- Security headers (mirror security/headers.ts) ---
    add_header Content-Security-Policy "default-src 'self'; base-uri 'self'; object-src 'none'; script-src 'self' 'wasm-unsafe-eval' https://accounts.google.com https://apis.google.com; frame-src 'self' https://accounts.google.com; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; font-src 'self' data:; connect-src 'self' https://www.googleapis.com https://accounts.google.com https://oauth2.googleapis.com; worker-src 'self'; manifest-src 'self'; form-action 'self'; frame-ancestors 'none'; upgrade-insecure-requests" always;
    add_header Strict-Transport-Security "max-age=31536000; includeSubDomains" always;
    add_header X-Content-Type-Options "nosniff" always;
    add_header X-Frame-Options "DENY" always;
    add_header Referrer-Policy "no-referrer" always;
    add_header Permissions-Policy "accelerometer=(), camera=(), geolocation=(), gyroscope=(), magnetometer=(), microphone=(), payment=(), usb=()" always;
    add_header Cross-Origin-Opener-Policy "same-origin-allow-popups" always;
    add_header Cross-Origin-Resource-Policy "same-origin" always;
    add_header X-DNS-Prefetch-Control "off" always;
    add_header X-Permitted-Cross-Domain-Policies "none" always;

    # Block dotfiles, env leaks, and source maps.
    location ~ /\. {
        deny all;
        return 404;
    }
    location ~* \.(map|env|local)$ {
        deny all;
        return 404;
    }

    # Service worker must not be cached aggressively.
    location = /sw.js {
        add_header Cache-Control "no-cache" always;
        try_files $uri =404;
    }

    location / {
        try_files $uri $uri/ /index.html;
        add_header Cache-Control $jackpass_asset_cache always;
    }

    # SPA shell: never cache HTML (ensures fresh bundles after deploy).
    location = /index.html {
        add_header Cache-Control "no-store" always;
    }
}
