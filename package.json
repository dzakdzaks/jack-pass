{
  "name": "jackpass",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "JackPass - zero-knowledge password manager PWA backed by Google Drive",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview --port 3000",
    "typecheck": "tsc -b --noEmit",
    "lint": "eslint src tests vite.config.ts playwright.config.ts eslint.config.js",
    "test": "vitest run tests/unit",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "audit": "bun audit"
  },
  "dependencies": {
    "hash-wasm": "^4.12.0",
    "idb": "^8.0.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-hook-form": "^7.54.2",
    "react-router-dom": "^7.1.5",
    "zod": "^3.24.1",
    "@hookform/resolvers": "^3.10.0",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.19.0",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/vite": "^4.0.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.2.0",
    "@types/node": "^25.9.3",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^9.19.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.18",
    "globals": "^15.14.0",
    "jsdom": "^26.0.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.22.0",
    "vite": "^6.1.0",
    "vite-plugin-pwa": "^0.21.1",
    "vitest": "^3.0.5"
  }
}
